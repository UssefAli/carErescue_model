# OBD Diagnostics microservice — environment template.
# Copy to .env for local dev. On Railway, set these in the service Variables tab.

ENVIRONMENT=development
APP_NAME=CarErescue OBD Diagnostics
VERSION=0.1.0

# Dataset
DATASET_DIR=app/data/etios
DEFAULT_VEHICLE_ID=etios-2014

# Networking (Railway injects PORT automatically; PORT below is for local only)
PORT=8001
# Comma-separated list, or ["*"] for all
CORS_ORIGINS=["*"]
